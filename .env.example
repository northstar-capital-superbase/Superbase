# ─────────────────────────────────────────────────────────────
# Northstar Labs — environment configuration
# Copy to `.env.local`. Everything is OPTIONAL: with no keys set,
# the lab runs in MOCK mode so the multi-agent workflow still works.
# ─────────────────────────────────────────────────────────────

# LLM provider: "anthropic" | "openai" | "mock" (auto-detected if unset)
LLM_PROVIDER=

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase (shared memory persistence). If unset, memory stays in-process.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
