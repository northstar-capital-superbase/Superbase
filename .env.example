# ─────────────────────────────────────────────────────────────
# Northstar Labs — environment configuration
# Copy to `.env.local`. Authentication (below) is REQUIRED — every private
# route (/labs, /settings, /connections) is gated behind real sign-in. An LLM
# key is also REQUIRED for the crew to answer — set ANTHROPIC_API_KEY
# (preferred) or OPENAI_API_KEY.
# ─────────────────────────────────────────────────────────────

# Supabase Auth (REQUIRED — accounts, profiles, per-user memory isolation).
# These are public by design (NOT secrets — Row Level Security is what
# actually protects data), so NEXT_PUBLIC_* is correct here.
#   1. Create/open a project at https://supabase.com/dashboard
#   2. Apply supabase/schema.sql (SQL editor or `supabase db push`)
#   3. Project Settings → API → copy the URL and anon/publishable key below
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Keep false until SMTP and a complete recovery/update-password flow are
# configured. The login UI hides "Forgot password" unless explicitly enabled.
NEXT_PUBLIC_PASSWORD_RESET_ENABLED=false

# LLM provider: "anthropic" | "openai" (auto-detected from the keys below)
LLM_PROVIDER=

# Anthropic / Claude (preferred)
ANTHROPIC_API_KEY=
# Default is the most capable Claude model. For faster/cheaper runs across the
# multi-call agent pipeline, set a smaller Claude model.
ANTHROPIC_MODEL=claude-opus-4-8
# Optional tuning (left unset = fastest valid request on any model):
#   ANTHROPIC_EFFORT: low | medium | high | xhigh | max  (Opus/Sonnet 4.6+)
#   ANTHROPIC_THINKING: set to "adaptive" to enable adaptive thinking
ANTHROPIC_EFFORT=
ANTHROPIC_THINKING=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Guardrails (cost/abuse protection on the run endpoints)
#   RATE_LIMIT_PER_MIN: max runs per client per minute (default 20)
#   MAX_TASK_CHARS: max task length (default 4000)
RATE_LIMIT_PER_MIN=
MAX_TASK_CHARS=

# Shared agent memory persistence. Per-user chat memory now authenticates as
# the signed-in user (NEXT_PUBLIC_SUPABASE_ANON_KEY + their session — RLS
# enforces isolation), so no extra config is needed once Auth above is set.
# SUPABASE_SERVICE_ROLE_KEY is OPTIONAL — only used for the unauthenticated
# /api/health?memory=1 diagnostic probe (bypasses RLS). If unset entirely,
# that one probe falls back to the anon key (may show a permission error,
# which is expected/harmless) or in-process memory if Auth isn't configured.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Robinhood Agentic Trading (optional)
# OAuth bearer token obtained during the Robinhood MCP connection flow.
# Setup: https://robinhood.com/us/en/support/articles/agentic-trading-overview/
#   Claude Code:  claude mcp add robinhood-trading --transport http https://agent.robinhood.com/mcp/trading
#   Cursor:       Settings → Tools & MCPs → Connect → https://agent.robinhood.com/mcp/trading
#   Other:        any MCP-compatible client + the URL above
# When set, the Trader specialist connects to your isolated Agentic account.
# When unset, the Trader runs in advisory mode (no live trades).
ROBINHOOD_MCP_TOKEN=
# Required while the token above is deployment-global. Comma-separated,
# case-insensitive emails; all other users see Robinhood as unavailable.
TRADING_ALLOWED_USER_EMAILS=
#
# Trading safety policy (enforced in code, not just the prompt):
#   TRADING_MODE: advisory (read-only) | confirm (human-approved orders) | auto
#     default "auto" — the Trader may place orders, subject to the caps below.
#   TRADING_MAX_ORDER_USD: max notional per order (default 100)
#   TRADING_MAX_ORDERS_PER_RUN: max order placements per run (default 3)
#   Optional, once you see the live tool names — correct the classifier:
#   TRADING_MUTATING_TOOLS / TRADING_READONLY_TOOLS (comma-separated names)
TRADING_MODE=auto
TRADING_MAX_ORDER_USD=100
TRADING_MAX_ORDERS_PER_RUN=3
