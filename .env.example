# ─────────────────────────────────────────────────────────────
# Northstar Labs — environment configuration
# Copy to `.env.local`. Everything is OPTIONAL: with no keys set,
# the lab runs in MOCK mode so the multi-agent workflow still works.
# ─────────────────────────────────────────────────────────────

# LLM provider: "anthropic" | "openai" | "mock" (auto-detected if unset)
LLM_PROVIDER=

# Anthropic / Claude
ANTHROPIC_API_KEY=
# Default is claude-opus-4-8 (most capable). For faster/cheaper local runs
# across the 5-call agent pipeline, set claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8
# Optional tuning (left unset = fastest valid request on any model):
#   ANTHROPIC_EFFORT: low | medium | high | xhigh | max  (Opus/Sonnet 4.6+)
#   ANTHROPIC_THINKING: set to "adaptive" to enable adaptive thinking
ANTHROPIC_EFFORT=
ANTHROPIC_THINKING=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Guardrails (cost/abuse protection on the run endpoints)
#   RATE_LIMIT_PER_MIN: max runs per client per minute (default 20)
#   MAX_TASK_CHARS: max task length (default 4000)
RATE_LIMIT_PER_MIN=
MAX_TASK_CHARS=

# Authentication & authorization (issue #17)
# The API routes (/api/chat, /api/chat/stream, /api/memory, /api/agents) require
# an authenticated caller. Two credential types are accepted:
#   1. A Supabase Auth user token — Authorization: Bearer <jwt> or an
#      sb-access-token cookie. Enable this by setting SUPABASE_URL + a Supabase
#      key (the NEXT_PUBLIC_* anon key works for browser sign-in).
#   2. A server-to-server service token below — Authorization: Bearer <token>.
# In production an unauthenticated request is rejected (401). In local dev
# (NODE_ENV != production) requests fall back to an explicit "dev-user" so the
# zero-config quick-start still works; this fallback can never activate in prod.
API_SERVICE_TOKEN=

# Supabase (shared memory persistence). Server-runtime vars (NOT NEXT_PUBLIC,
# which Next.js inlines at build time). If unset, memory stays in-process.
# Apply supabase/schema.sql to your project first.
SUPABASE_URL=
# Secret service_role key — bypasses RLS; server-side only. Preferred.
SUPABASE_SERVICE_ROLE_KEY=
# Optional publishable/anon key (respects RLS — needs table policies to work).
SUPABASE_ANON_KEY=

# Robinhood Agentic Trading (optional)
# OAuth bearer token obtained during the Robinhood MCP connection flow.
# Setup: https://robinhood.com/us/en/support/articles/agentic-trading-overview/
#   Claude Code:  claude mcp add robinhood-trading --transport http https://agent.robinhood.com/mcp/trading
#   Cursor:       Settings → Tools & MCPs → Connect → https://agent.robinhood.com/mcp/trading
#   Other:        any MCP-compatible client + the URL above
# When set, the Trader specialist connects to your isolated Agentic account.
# When unset, the Trader runs in advisory mode (no live trades).
ROBINHOOD_MCP_TOKEN=
#
# Trading safety policy (enforced in code, not just the prompt):
#   TRADING_MODE: advisory (read-only) | confirm (human-approved orders) | auto
#     default "auto" — the Trader may place orders, subject to the caps below.
#   TRADING_MAX_ORDER_USD: max notional per order (default 100)
#   TRADING_MAX_ORDERS_PER_RUN: max order placements per run (default 3)
#   Optional, once you see the live tool names — correct the classifier:
#   TRADING_MUTATING_TOOLS / TRADING_READONLY_TOOLS (comma-separated names)
TRADING_MODE=auto
TRADING_MAX_ORDER_USD=100
TRADING_MAX_ORDERS_PER_RUN=3
